    <bean id="wmRankMsgThriftServicePublisher"
          class="com.meituan.service.mobile.mtthrift.proxy.ThriftServerPublisher"
          init-method="publish" destroy-method="destroy" lazy-init="false">
        <property name="serviceInterface"
                  value="com.sankuai.meituan.waimai.thrift.rank.msg.iface.WmRankMsgThriftIface"/>
        <!-- 指定service接口类 -->
        <property name="serviceImpl" ref="wmRankMsgThriftIfaceImpl"/>
        <property name="selectorThreads" value="4"/>
        <!-- 可不配置，默认4 -->
        <property name="minWorkerThreads" value="20"/>
        <!-- 可不配置，默认10 -->
        <property name="port" value="9110"/>
        <!-- 服务端口号 -->
        <property name="daemon" value="true"/>
        <!-- 是否后台线程，可不配置，默认值true -->
        <property name="appKey" value="${octo.key}"/>
        <!-- 设置appkey -->
        <property name="clusterManager" value="${octo.clusterManager}"/>
        <!-- 设置工作模式 -->
        <property name="shutdownWaitTime" value="5"/>
        <!-- 服务端延迟停止时间(秒)即优雅关闭，默认是10 -->
        <property name="maxWorkerThreads" value="50"/>
        <!-- 服务端最大线程数 -->
        <!--<property name="authHandler" ref="defaultAuthHandler" />-->
    </bean>


