    <bean id="distributedLockManager"
          class="com.meituan.hotel.dlm.service.impl.DistributedLockManager"
          init-method="init" destroy-method="destroy" scope="singleton">
        <constructor-arg value="tair" />       <!-- 可选value为："zk"、"tair"、"squirrel"；可配多个，按先后顺序第一个为主引擎，其他为备用引擎 -->
        <constructor-arg value="zk" />
        <constructor-arg value="squirrel" />
        <property name="appKey" value="${octo.key}"/>        <!-- 必填。业务方设置的appKey，用于区分业务唯一的分布式锁，建议用octo的appKey -->
        <property name="tairConfigModel" ref="tairConfigModel" />                <!-- 选填。如不填，将使用tair默认公用集群。 -->
    </bean>

